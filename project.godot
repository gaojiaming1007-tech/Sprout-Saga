config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Sprout Sage1.0"
run/main_scene="uid://clljuhyrto2cy"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://c7s7e61d44oq2"

[autoload]

ImGuiRoot="*uid://dugmpnsxaagba"
GameManager="*uid://bxsmx1kamcgkx"
UtilsManager="*uid://dtmfq1hgse1vp"
LoadingManager="*uid://1xtc63hpoub"
ResourceManager="*uid://ddo1mqskyb7nl"
PhantomCameraManager="*uid://duq6jhf6unyis"
Cursor="*uid://djwpw33d4d8u7"

[display]

